# ==================== Backend ====================

# Database (local docker)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mockinterview
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- LLM Provider (PLUGGABLE) ----------
# Set LLM_PROVIDER to either "groq" or "openai"
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

GROQ_API_KEY=gsk_xxx
OPENAI_API_KEY=sk-xxx
# ---------------------------------------------

# Speech services
DEEPGRAM_API_KEY=xxx

# TTS provider: "elevenlabs" or "openai"
TTS_PROVIDER=elevenlabs

# OpenAI TTS (used when TTS_PROVIDER=openai)
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

# ElevenLabs (used when TTS_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=xxx
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Google OAuth (only third-party auth provider)
GOOGLE_CLIENT_ID=97724911737-i76lte161mjjnipdkpc9o4hdg9l3bgsn.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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

# Local object storage (MinIO)
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=mockinterview
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# Gmail SMTP (use an App Password, not your account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM=your-gmail@gmail.com
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# CORS
CORS_ORIGINS=http://localhost:5173

# Frontend (for password reset email links)
FRONTEND_URL=http://localhost:5173
